node_modules/
.next/
.next.pre-release-build-*/
out/
dist/
coverage/
*.log
.DS_Store

# Local environment and machine-specific agent surfaces.
.env
.env.*
!.env.example
.codex/
.ncode/
state.yaml

# Next/TypeScript generated state.
tsconfig.tsbuildinfo

# Runtime evaluation data. This contains local stats, transcripts, workdirs,
# SQLite WAL files, and run artifacts that should stay on the operator machine.
data/

# Throwaway data root used by `npm test` (OPENEVAL_DATA_ROOT=.test-data).
.test-data/

# Raw /optimize measurement artifacts embed absolute machine paths and
# transcript-derived data (public-upload-audit rejects them). The numbers that
# matter are copied into .optimize/ledger.md + baseline.json, which stay tracked.
.optimize/runs/

# HyperFrames preview/render/cache output.
media/**/.hyperframes/
media/**/.thumbnails/
media/**/renders/*

# Launch-film production projects and source assets stay outside the product repository.
media/openeval-launch/
media/openeval-launch-v3/

# Fixture runtime clutter.
fixtures/**/node_modules/
fixtures/**/.git/
fixtures/**/.DS_Store

# Local Claude Code launch/config surfaces.
.claude/
